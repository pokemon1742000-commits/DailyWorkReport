{
  "name": "daily_work_report",
  "version": "1.5.7",
  "description": "Phần mềm chuẩn hóa báo cáo công việc hằng ngày, quản lý SQLite, thư mục ảnh/tài liệu và xuất báo cáo tuần Excel.",
  "main": "main.js",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=& electron .",
    "start:hidden": "wscript \"Run Daily Work Report.vbs\"",
    "build": "electron-builder --win --x64",
    "build:installer": "electron-builder --win nsis --x64",
    "package:unpacked": "node scripts/package-unpacked.js",
    "build:release": "npm run build && npm run package:unpacked",
    "release:auto": "node scripts/release.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@mediapipe/hands": "^0.4.1675469240",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "sql.js": "^1.14.1"
  },
  "build": {
    "appId": "com.dailywork.report",
    "productName": "Daily Work Report",
    "publish": [
      {
        "provider": "github",
        "owner": "pokemon1742000-commits",
        "repo": "DailyWorkReport"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "compression": "maximum",
    "files": [
      "main.js",
      "index.html",
      "assets/**/*",
      "reference_files/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/daily-work-report-icon.ico",
      "requestedExecutionLevel": "requireAdministrator",
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-v${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-v${version}.${ext}",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "${productName}",
      "deleteAppDataOnUninstall": false
    }
  }
}
